{
  "name": "@relay/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "wrangler deploy --dry-run --outdir dist",
    "db:apply:local": "wrangler d1 execute relay-db --local --file=src/schema.sql",
    "db:apply:remote": "wrangler d1 execute relay-db --remote --file=src/schema.sql",
    "lint:migrations": "bash scripts/lint-migrations.sh",
    "test:migrations": "bash scripts/test-migrations.sh"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/oauth-providers": "^0.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251201.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
